# ==========================================================
# DATA CLEANING & PREPROCESSING PIPELINE
# ==========================================================

import pandas as pd
import numpy as np

# -----------------------------
# STEP 1: LOAD DATASET
# -----------------------------

df = pd.read_csv("../dataset/Students Performance Dataset.csv")

print("="*60)
print("ORIGINAL DATASET")
print("="*60)

print("\nShape:", df.shape)

print("\nMissing Values:")
print(df.isnull().sum())

print("\nDuplicate Records:",
      df.duplicated().sum())

# -----------------------------
# STEP 2: CREATE WORKING COPY
# -----------------------------

clean_df = df.copy()

# -----------------------------
# STEP 3: REMOVE DUPLICATES
# -----------------------------

clean_df.drop_duplicates(
    inplace=True
)

# -----------------------------
# STEP 4: HANDLE MISSING VALUES
# -----------------------------

# Parent Education Level

clean_df[
    'Parent_Education_Level'
] = clean_df[
    'Parent_Education_Level'
].fillna(
    clean_df[
        'Parent_Education_Level'
    ].mode()[0]
)

# -----------------------------
# STEP 5: REMOVE IRRELEVANT
# COLUMNS
# -----------------------------

columns_removed = [
    'Student_ID',
    'First_Name',
    'Last_Name',
    'Email'
]

clean_df.drop(
    columns=columns_removed,
    inplace=True
)

# -----------------------------
# STEP 6: REMOVE EXTRA SPACES
# FROM TEXT COLUMNS
# -----------------------------

for col in clean_df.select_dtypes(
    include=['object','string']
).columns:

    clean_df[col] = (
        clean_df[col]
        .astype(str)
        .str.strip()
    )

# -----------------------------
# STEP 7: VERIFY DATA TYPES
# -----------------------------

print("\nData Types:\n")
print(clean_df.dtypes)

# -----------------------------
# STEP 8: FINAL VALIDATION
# -----------------------------

print("\n" + "="*60)
print("AFTER CLEANING")
print("="*60)

print("\nFinal Shape:",
      clean_df.shape)

print("\nRemaining Missing Values:")

print(
    clean_df
    .isnull()
    .sum()
)

print("\nDuplicate Records:",
      clean_df.duplicated().sum())

print("\nColumns Removed:")
print(columns_removed)

print("\nRemaining Features:")

for col in clean_df.columns:
    print(col)

print("\nData Cleaning Completed Successfully")

